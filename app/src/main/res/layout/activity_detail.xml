<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgAfficheDetail"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvTitreDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#E0E0E0"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNoteDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#C9A84C"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvSynopsisDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#888888"
            android:textSize="14sp" />

        <!-- TableLayout -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:stretchColumns="1">

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Genre :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="Action"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Langue :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="Français"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Statut :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="En collection"
                    android:textColor="#C9A84C"
                    android:textSize="13sp" />
            </TableRow>

        </TableLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#16213E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:text="Statut :"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerStatut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#E0E0E0"
            android:text="Ma note :"
            android:textSize="14sp" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:stepSize="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#E0E0E0"
            android:text="Mon avis :"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etAvis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#C9A84C"
            android:hint="Écris ton avis ici..."
            android:textColor="#E0E0E0"
            android:textColorHint="#888888"
            android:minLines="3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#E0E0E0"
            android:text="Date de visionnage :"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#16213E"
            android:text="Choisir une date"
            android:textColor="#C9A84C" />

        <TextView
            android:id="@+id/tvDateChoisie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#C9A84C"
            android:text=""
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnAjouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#C9A84C"
            android:text="Ajouter à ma collection"
            android:textColor="#1A1A2E" />

    </LinearLayout>

</ScrollView>