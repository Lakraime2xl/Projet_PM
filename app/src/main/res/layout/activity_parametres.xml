<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213E"
        android:padding="8dp"
        android:title="Paramètres"
        android:titleTextColor="#C9A84C" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Ton nom :"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etNom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:backgroundTint="#C9A84C"
        android:hint="Entre ton nom..."
        android:textColor="#E0E0E0"
        android:textColorHint="#888888" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Thématique :"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etThematique"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:backgroundTint="#C9A84C"
        android:hint="Ex: Films d'action"
        android:textColor="#E0E0E0"
        android:textColorHint="#888888" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Notifications :"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchNotifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Activer les notifications"
        android:textColor="#E0E0E0" />

    <CheckBox
        android:id="@+id/checkBoxAdulte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Afficher les films adultes"
        android:textColor="#E0E0E0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Langue :"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/radioGroupLangue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <RadioButton
            android:id="@+id/radioFr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Français"
            android:textColor="#E0E0E0"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radioEn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anglais"
            android:textColor="#E0E0E0" />

    </RadioGroup>

    <Button
        android:id="@+id/btnSauvegarder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="#C9A84C"
        android:text="Sauvegarder"
        android:textColor="#1A1A2E" />

</LinearLayout>