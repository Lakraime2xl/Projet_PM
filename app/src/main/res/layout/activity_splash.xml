<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <!-- Nom de l'application, centré dans l'écran -->
    <TextView
        android:id="@+id/tvNomApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="ACTION ZONE"
        android:textColor="#E24B4A"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Slogan sous le nom -->
    <TextView
        android:id="@+id/tvSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvNomApp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Ta collection de films d'action"
        android:textColor="#888888"
        android:textSize="14sp" />

    <!-- Barre de chargement en bas de l'écran -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp" />

</RelativeLayout>